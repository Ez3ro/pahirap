# Copy this file to ".env" and fill in your own values.
# Find both in your Supabase dashboard under Settings -> API.
# Use the "anon public" key here, NEVER the service_role key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Push notifications: the PUBLIC half of your VAPID key pair (safe to expose).
# Generate both halves with:  npx web-push generate-vapid-keys
# Put the public key here; the private key goes in Supabase (see PUSH_SETUP.md).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
